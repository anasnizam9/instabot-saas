APP_NAME=InstaBot SaaS API
APP_ENV=development
SECRET_KEY=replace-this-with-a-strong-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
DATABASE_URL=sqlite+aiosqlite:///./instabot.db
AUTO_CREATE_TABLES=false
LOG_LEVEL=INFO
REQUEST_ID_HEADER=X-Request-ID

SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_SECONDS=30
SCHEDULER_BATCH_SIZE=20
SCHEDULER_AUTOMATION_INTERVAL_SECONDS=300
SCHEDULER_STUCK_CHECK_INTERVAL_SECONDS=120
SCHEDULER_CLEANUP_INTERVAL_HOURS=24

PUBLISHER_MAX_ATTEMPTS=3
PUBLISHER_RETRY_BASE_DELAY_SECONDS=60
PUBLISHER_RETRY_JITTER_RATIO=0.15
PUBLISHER_STUCK_TIMEOUT_MINUTES=15

WEBHOOK_MAX_AGE_SECONDS=600
WEBHOOK_EVENT_RETENTION_DAYS=14

INSTAGRAM_APP_ID=your-meta-app-id
INSTAGRAM_APP_SECRET=your-meta-app-secret
INSTAGRAM_REDIRECT_URI=http://127.0.0.1:8000/api/v1/instagram/oauth/callback
INSTAGRAM_API_VERSION=v23.0
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=instabot-webhook-verify-token
ENCRYPTION_KEY=your-32-char-min-encryption-key

# Production notes:
# - Set APP_ENV=production
# - Keep AUTO_CREATE_TABLES=false
# - SECRET_KEY and ENCRYPTION_KEY must be non-default, strong values
